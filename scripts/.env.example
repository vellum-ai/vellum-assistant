# scripts/.env — Configuration for helper scripts (e.g. fetch-qr-code.sh).
# Copy this file to scripts/.env and fill in the values.

# SSH host of the Mac mini (required).
# Can include the user, e.g. myuser@192.168.1.50
MAC_MINI_HOST=192.168.1.50

# SSH user for the Mac mini (optional if included in MAC_MINI_HOST above).
MAC_MINI_USER=

# Remote directory on the Mac mini where staging DMGs are placed (optional).
# Defaults to ~/Downloads if not set.
MAC_MINI_DMG_DEST='~/Downloads'
