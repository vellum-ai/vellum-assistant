# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/
# Per-file test durations written by scripts/test.sh for longest-first
# scheduling; produced/consumed in CI, never committed.
.test-durations

# next.js
.next/
/out/

# production
/build
dist

# @vellumai/plugin-api publish build (generated by scripts/build-plugin-api.ts)
.plugin-api-build/

# storybook
storybook-static/

# Generated from meta/feature-flags/feature-flag-registry.json
assistant/src/config/feature-flag-registry.json
gateway/src/feature-flag-registry.json

# misc
worktrees/
.worktrees/
.codex-worktrees/
*-worktrees/
.playwright-mcp/
.DS_Store
.githooks/.githooks
*.pem
*.crx
.qdrant-initialized
.claude/*
!.claude/commands/
!.claude/phases/
!.claude/skills/
!.claude/hooks/
!.claude/README.md
!.claude/settings.json

# Shared claude-skills symlinks are gitignored; only repo-local skills are tracked.
.claude/skills/*
!.claude/skills/update/
!.claude/skills/release/
!.claude/skills/vellum-skills/
!.claude/skills/cli-testing/

# Shared claude-skills symlinks (managed by claude-skills/setup)
# These are gitignored because they're symlinks to the shared repo.
# Repo-local commands now live in .claude/skills/<name>/ as local skill directories.
.claude/commands/*.md
.claude/phases/
.plans/
.private/
temp.sh
context.md
/CLAUDE.md
.agents/*
!.agents/skills/

# Shared claude-skills symlinks under .agents/skills/ are gitignored; only
# repo-local skills are tracked. Mirrors the .claude/skills/ pattern above.
.agents/skills/*
!.agents/skills/testing-design-library-storybook/
.codex
.vellum

# IDE
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# xcode / spm build artifacts
.build
.build/
.derivedData/
*.xcactivitylog
*.o
DerivedData/

# drizzle
web/drizzle/

# typescript
*.tsbuildinfo
next-env.d.ts

# terraform
**/.terraform/*
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# MCP config
.mcp.json

# bun build artifacts
*.bun-build
vellum-assistant-safe-do-permissions
vellum-assistant-do-fix-retriever-null-check

# Chrome browser extension build
clients/chrome-extension/vellum-browser-relay.zip

# Drizzle migration files — schema is applied via drizzle-kit push at runtime
gateway/src/db/migrations/

# Chrome extension builds
clients/chrome-extension/vellum-browser-relay.zip

# vel command
clients/web/.vel/watchers.json

# Build-generated skill assets copied into SPA public dir
clients/web/public/skills/

# Generated at release time by the publish-meta jobs (release.yml)
meta/package-lock.json
meta/npm-shrinkwrap.json

# Eval run artifacts — local only, never committed
evals/
