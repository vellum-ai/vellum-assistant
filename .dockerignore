# Build images from the repository root but keep context minimal.
**
# Workspace install inputs: the deps stage resolves from the root manifest,
# lockfile, member manifests, and patch files — no source.
!package.json
!bun.lock
!patches/
!patches/**
!clients/macos/package.json
!clients/web/package.json
!cli/package.json
# Although we have a `**` ignore that correctly excludes large build artifacts from the build context,
# it seems the walker doesn't prune a directory when there are `!` exceptions that can include files
# beneath that directory. This manifests as an extremely long build context load time.
# Adding an explicit exclusion rule seems to help with this.
clients/.build
clients/ios
clients/chrome-extension
clients/macos/apple-containers-runtime
clients/macos/dist
clients/macos/native
clients/macos/node_modules
clients/macos/out
clients/macos/src
!assistant/
!assistant/**
!credential-executor/
!credential-executor/**
!gateway/
!gateway/**
!packages/
!packages/**
!skills/
# Shared category taxonomy: the daemon reads this synchronously to normalize
# plugin marketplace categories without a remote fetch (see
# assistant/src/skills/categories-cache.ts getLocalCategorySlugs). Without it the
# Docker image degrades every plugin category to "system" until the remote cache warms.
!skills/skill-categories-catalog.yaml
!skills/meet-join/
!skills/meet-join/package.json
!skills/meet-join/bun.lock
!skills/meet-join/config-schema.ts
!skills/meet-join/meet-config.ts
!skills/meet-join/register.ts
!skills/meet-join/contracts/
!skills/meet-join/contracts/**
!skills/meet-join/daemon/
!skills/meet-join/daemon/**
!skills/meet-join/tools/
!skills/meet-join/tools/**
!skills/meet-join/routes/
!skills/meet-join/routes/**
!skills/meet-join/shared/
!skills/meet-join/shared/**
!skills/meet-join/scripts/
!skills/meet-join/scripts/**

# Plugin marketplace manifest: the offline plugin catalog reader statically
# imports this (assistant/src/cli/lib/plugin-catalog-local.ts, loaded even when
# platform features are enabled). It is the canonical source for the git-ignored
# assistant/src/cli/lib/bundled-marketplace.json, which the Dockerfile copies
# into place. Without it the assistant image cannot resolve that import.
!plugins/
!plugins/marketplace.json

# Exclude local dependencies and build outputs from included directories.
assistant/dist/
assistant/out/
assistant/build/
assistant/.env
assistant/.env.*
# Authoring-reference example plugins are not shipped with the production image.
assistant/examples/
credential-executor/.env
credential-executor/.env.*
gateway/.env
gateway/.env.*
packages/*/.env
packages/*/.env.*
skills/meet-join/**/__tests__/
skills/meet-join/**/*.test.ts

**/node_modules/
