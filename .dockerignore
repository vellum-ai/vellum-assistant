# Build images from the repository root but keep context minimal.
**
!assistant/
!assistant/**
!cli/
!cli/**
!credential-executor/
!credential-executor/**
!packages/
!packages/**

# Exclude local dependencies and build outputs from included directories.
assistant/node_modules/
assistant/dist/
assistant/out/
assistant/build/
assistant/.env
assistant/.env.*
cli/node_modules/
cli/dist/
cli/out/
cli/build/
cli/.env
cli/.env.*
credential-executor/node_modules/
credential-executor/.env
credential-executor/.env.*
packages/*/node_modules/
packages/*/.env
packages/*/.env.*
