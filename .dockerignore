# Build the assistant image from the repository root but keep context minimal.
**
!assistant/
!assistant/**
!cli/
!cli/**

# Exclude local dependencies and build outputs from included packages.
assistant/node_modules/
assistant/dist/
assistant/out/
assistant/build/
assistant/.env
assistant/.env.*

cli/node_modules/
cli/dist/
cli/out/
cli/build/
cli/.env
cli/.env.*
