# Root .env — copy to .env and fill in values. This file is gitignored.
# Existing environment variables take precedence over values here.

# --- Sentry (crash reporting) ---
# Omit or leave empty to disable Sentry in local builds.
SENTRY_DSN_ASSISTANT=

# --- Network proxy ---
# Comma-separated host patterns allowed through the proxy.
# localhost is always allowed.
PROXY_ALLOWED_HOSTS=*.vellum.ai

# --- Vellum docs ---
# Override the Vellum docs base URL (macOS app links). Used for staging/local docs servers.
# Defaults to https://www.vellum.ai/docs. Must be a parseable absolute http(s) URL with no
# query or fragment, otherwise the override is ignored and the default is used.
# VELLUM_DOCS_BASE_URL=https://staging.vellum.ai/docs

# --- Atlas Cloud (OpenAI-compatible LLM provider) ---
# Atlas Cloud provides 59+ LLM models via a single OpenAI-compatible API.
# Sign up at https://www.atlascloud.ai/console/coding-plan to get API credits.
# ATLAS_BASE_URL=https://api.atlascloud.ai/v1
# ATLAS_API_KEY=<your-atlascloud-api-key>
