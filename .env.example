# Database Connection (PostgreSQL)
# For local development with Docker Compose:
DATABASE_URL=postgresql://vellum:password@localhost:5432/vellum

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud (for compute/storage)
GCP_SA_KEY={"type":"service_account",...}
GCP_PROJECT_ID=your-project
GCS_BUCKET_NAME=your-bucket

# App URL (for callbacks/webhooks)
APP_URL=http://localhost:3000

# Feature Flags
# Set to "true" to show the full Platform Login screen (username/password form).
# When not set or set to any other value, a simple "Get Started!" button is shown instead.
NEXT_PUBLIC_PLATFORM_LOGIN_ENABLED=true
