{
  "name": "vellum-assistant-playwright",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:verbose": "VERBOSE=1 playwright test",
    "test:ci": "bun run scripts/agent-ci.ts",
    "test:ci:detach": "bun run scripts/agent-ci.ts -d",
    "test:ci:xcode": "bun run scripts/agent-ci.ts --xcode"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1"
  }
}
