{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "jsx": "react-jsx",
    "types": ["bun-types"]
  },
  "include": [
    "src/**/*",
    "src/**/*.tsx",
    "../skills/meet-join/daemon/**/*.ts",
    "../skills/meet-join/tools/**/*.ts",
    "../skills/meet-join/routes/**/*.ts",
    "../skills/meet-join/contracts/**/*.ts",
    "../skills/meet-join/config-schema.ts"
  ],
  "exclude": ["node_modules", "dist", "drizzle", "../skills/meet-join/bot"]
}
