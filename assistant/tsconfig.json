{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "..",
    "jsx": "react-jsx",
    "types": ["bun-types"]
  },
  "include": ["src/**/*", "src/**/*.tsx", "../skills/**/*"],
  "exclude": ["node_modules", "dist", "drizzle"]
}
