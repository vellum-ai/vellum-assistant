    {
      "name": "gmail_draft",
      "description": "Create a draft email in Gmail. The draft will appear in Gmail Drafts for user review.",
      "category": "gmail",
      "risk": "low",
      "input_schema": {
        "type": "object",
        "properties": {
          "to": {
            "type": "string",
