{
  "version": 1,
  "tools": [
    {
      "name": "gmail_archive",
      "description": "Archive Gmail messages (remove from inbox). Accepts a single message_id, an array of message_ids, scan_id + sender_ids from a prior scan, or a query to archive all matches. Include a confidence score (0-1).",
      "category": "gmail",
      "risk": "medium",
      "input_schema": {
        "type": "object",
        "properties": {
          "message_id": {
            "type": "string",
            "description": "Gmail message ID to archive"
          },
          "message_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Gmail message IDs to archive (for batch operations)"
          },
          "scan_id": {
            "type": "string",
            "description": "Scan result ID from a prior gmail_sender_digest or gmail_outreach_scan call"
          },
          "sender_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Sender IDs to archive (used with scan_id)"
          },
          "query": {
            "type": "string",
            "description": "Gmail search query to archive all matching messages"
          },
          "confidence": {
            "type": "number",
            "description": "Confidence score (0-1) for this action"
          },
          "reason": {
            "type": "string",
            "description": "Brief non-technical explanation of why this tool is being called"
          }
        },
        "required": ["confidence"]
      },
      "executor": "tools/gmail-archive.ts",
      "execution_target": "host"
    },
