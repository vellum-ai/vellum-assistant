# Simulator LLM API key — required for running tests with the Haiku-backed simulator.
# Used by PR-3+ harness; PR-1 (scaffold) does not invoke any LLM.
ANTHROPIC_API_KEY=

# Optional overrides for definition lookups.
# Defaults to <evals-pkg-dir>/profiles and <evals-pkg-dir>/tests.
# EVALS_PROFILES_DIR=
# EVALS_TESTS_DIR=

# Optional ngrok authtoken for `evals server --ngrok`. When set, the
# evals harness forwards it to the ngrok agent (`--authtoken <token>`),
# so you don't have to `ngrok config add-authtoken` separately. Without
# it, ngrok still works on the free tier — short-lived random
# *.ngrok-free.app URL with session-timeout limits. Sign up + grab a
# token at https://dashboard.ngrok.com.
# NGROK_AUTH_TOKEN=
