# Simulator LLM API key — required for running tests with the Haiku-backed simulator.
# Used by PR-3+ harness; PR-1 (scaffold) does not invoke any LLM.
ANTHROPIC_API_KEY=

# Optional overrides for definition lookups.
# Defaults to <evals-pkg-dir>/profiles and <evals-pkg-dir>/tests.
# EVALS_PROFILES_DIR=
# EVALS_TESTS_DIR=

# ngrok authtoken — used by `evals server --ngrok` to expose the local
# report server via a stable ngrok HTTPS tunnel. The `ngrok` agent
# reads this env var natively at startup, so no `ngrok config
# add-authtoken` step is required when this is set.
# Without a token, ngrok still works against the random ephemeral
# subdomain but is rate-limited and the session times out after ~2h.
# NGROK_AUTHTOKEN=
