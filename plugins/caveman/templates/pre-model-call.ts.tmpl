 * call, so the assistant communicates in caveman mode on every turn.
 */

import type { PreModelCallContext } from "@vellumai/plugin-api";

const MARKER = "<!-- caveman:terse-mode -->";

const RULESET = {{{RULESET_JSON}}};

export default function preModelCall(ctx: PreModelCallContext): void {
  // Only shape the user-facing reply; leave background/utility calls untouched.
  if (ctx.callSite !== "mainAgent") return;
  if (ctx.systemPrompt === undefined) return;
  // Idempotent: the hook fires once per model call within a turn, so guard
  // against appending the ruleset more than once.
  if (ctx.systemPrompt.includes(MARKER)) return;
  ctx.systemPrompt = `${ctx.systemPrompt}\n\n${MARKER}\n${RULESET}`;
}
