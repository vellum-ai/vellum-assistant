{
  "name": "@vellumai/desktop-shell",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "Cross-platform Electron main-process + preload runtime shared by the desktop clients (macOS, Linux).",
  "type": "module",
  "exports": {
    "./main/*": "./src/main/*.ts",
    "./preload": "./src/preload/index.ts"
  },
  "scripts": {
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test",
    "test:ci": "bun scripts/run-tests.ts"
  },
  "dependencies": {
    "@sentry/electron": "7.13.0",
    "@vellumai/environments": "workspace:*",
    "@vellumai/ipc-contract": "workspace:*",
    "@vellumai/local-mode": "workspace:*",
    "electron-log": "5.4.4",
    "electron-store": "11.0.2",
    "electron-updater": "6.8.9",
    "jszip": "3.10.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "electron": ">=42.0.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/node": "22.10.5",
    "electron": "42.2.0",
    "typescript": "5.9.3"
  }
}
