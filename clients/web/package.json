    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.14",
    "@types/js-yaml": "4.0.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "happy-dom": "20.10.2",
    "js-yaml": "4.1.1",
    "storybook": "10.4.0",
    "tailwindcss": "4.1.8",
    "typescript": "5.9.3",
