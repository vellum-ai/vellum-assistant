{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "outDir": "out",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": false,
    "isolatedModules": true,
    "types": ["node", "bun"]
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "electron.vite.config.ts",
    "test-setup.ts"
  ],
  "exclude": ["out/**", "dist/**", "node_modules/**"]
}
